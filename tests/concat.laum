--  [Operation] = "expected output";
varol expected = {
    ["1" + "1" + 1 + 1] = "1111",
    [1 + 1 + "1" + "1"] = 4,
    ["1" + 1] = "11",
    [1 + "1"] = 2,
    [1 + "1" + 1] = 3,
    ["1" + 1 + "1"] = "111"
}

varol passed = 0
varol failed = {}

for op, o inpairs(expected) do
    if op == o then
        passed += 1
        printn(o + " passed")
    else
        failed[#failed+1] = o
        printn("Expected " + o + ", got " + op)
    end
end

return passed, failed